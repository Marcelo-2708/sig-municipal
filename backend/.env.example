# ============================================================
# SIG Municipal — Variables de Entorno (Backend)
# ============================================================
# INSTRUCCIONES:
#   1. Copiar este archivo:  cp .env.example .env
#   2. Completar TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subir el archivo .env al repositorio
#
# El archivo .env está en .gitignore por seguridad.
# ============================================================

# ------------------------------------------------------------
# ENTORNO DE EJECUCIÓN
# Valores válidos: development | production | test
# ------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------
# SERVIDOR
# ------------------------------------------------------------
PORT=3000
HOST=0.0.0.0

# ------------------------------------------------------------
# BASE DE DATOS PostgreSQL + PostGIS
# ------------------------------------------------------------
DB_USER=sig_usuario
DB_PASSWORD=<CAMBIAR_contrasena_segura>
DB_NAME=sig_municipal
DB_HOST=sig_postgres
DB_PORT=5432
# Tamaño del pool de conexiones
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000

# ------------------------------------------------------------
# AUTENTICACIÓN JWT
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=<CAMBIAR_secreto_jwt_minimo_64_caracteres>
# Duración del access token (ej: 15m, 1h)
JWT_ACCESS_EXPIRA=15m
# Duración del refresh token (ej: 7d, 30d)
JWT_REFRESH_EXPIRA=7d

# ------------------------------------------------------------
# GEOSERVER
# ------------------------------------------------------------
GEOSERVER_URL=http://sig_geoserver:8080/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=<CAMBIAR_contrasena_geoserver>

# ------------------------------------------------------------
# DOMINIO Y MULTI-TENANCY
# Dominio base para resolver subdominios de cada municipalidad
# Ejemplo: DOMINIO_BASE=sig.municipalidad.cl
#   → sig.concepcion.cl resuelve al municipio "concepcion"
# ------------------------------------------------------------
DOMINIO_BASE=sig.municipalidad.cl

# ------------------------------------------------------------
# LOGGING
# Valores válidos: trace | debug | info | warn | error | fatal
# ------------------------------------------------------------
LOG_LEVEL=info
