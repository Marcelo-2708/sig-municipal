{
  "name": "sig-municipal-backend",
  "version": "1.0.0",
  "description": "API REST para la plataforma WebGIS multi-tenant SIG Municipal",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch src --watch server.js --ext js server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "fastify": "^4",
    "@fastify/cors": "^8",
    "@fastify/helmet": "^11",
    "@fastify/rate-limit": "^9",
    "@fastify/jwt": "^8",
    "@fastify/swagger": "^8",
    "@fastify/swagger-ui": "^3",
    "pg": "^8",
    "bcryptjs": "^2",
    "zod": "^3",
    "pino": "^8",
    "pino-pretty": "^11",
    "dotenv": "^16"
  },
  "devDependencies": {
    "vitest": "^1",
    "nodemon": "^3"
  }
}
