# ============================================================
# SIG Municipal — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copiar este archivo:  cp .env.example .env
#   2. Completar TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subir el archivo .env al repositorio
#
# El archivo .env está en .gitignore por seguridad.
# ============================================================

# ------------------------------------------------------------
# ENTORNO DE EJECUCIÓN
# Valores válidos: development | production | test
# ------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------
# BASE DE DATOS PostgreSQL + PostGIS
# ------------------------------------------------------------
DB_USER=sig_usuario
DB_PASSWORD=<CAMBIAR_contrasena_segura>
DB_NAME=sig_municipal
DB_HOST=sig_postgres
DB_PORT=5432
# Variables que el contenedor postgis/postgis lee directamente por estos nombres.
# Deben tener el mismo valor que DB_USER / DB_PASSWORD / DB_NAME.
POSTGRES_USER=sig_usuario
POSTGRES_PASSWORD=<CAMBIAR_contrasena_segura>
POSTGRES_DB=sig_municipal

# ------------------------------------------------------------
# GEOSERVER
# ------------------------------------------------------------
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=<CAMBIAR_contrasena_geoserver>
# URL interna usada por el backend para comunicarse con GeoServer
GEOSERVER_URL=http://sig_geoserver:8080/geoserver

# ------------------------------------------------------------
# REDIS — Caché en memoria
# ------------------------------------------------------------
# En desarrollo no se requiere contraseña (REDIS_PASSWORD vacío)
REDIS_PASSWORD=<CAMBIAR_contrasena_redis_en_prod>
# Para desarrollo: redis://sig_redis:6379
# Para producción: redis://:${REDIS_PASSWORD}@sig_redis:6379
REDIS_URL=redis://sig_redis:6379

# ------------------------------------------------------------
# AUTENTICACIÓN JWT
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET=<CAMBIAR_secreto_jwt_minimo_64_caracteres>

# ------------------------------------------------------------
# DOMINIO Y MULTI-TENANCY
# Dominio base para construir subdominios de cada municipalidad
# Ejemplo: sig.municipalidad.cl  →  sig.concepcion.cl
# ------------------------------------------------------------
DOMINIO_BASE=sig.municipalidad.cl

# ------------------------------------------------------------
# FRONTEND (variables expuestas al navegador con prefijo VITE_)
# ------------------------------------------------------------
# URL pública de la API REST (la que usa el navegador del ciudadano)
VITE_API_URL=http://localhost:3000
# URL pública de GeoServer (accesible desde el navegador)
VITE_GS_URL=http://localhost:8080/geoserver

# ------------------------------------------------------------
# NGINX / SSL (solo producción)
# ------------------------------------------------------------
# Correo para registro de certificados Let's Encrypt
LETSENCRYPT_EMAIL=<CAMBIAR_correo_administrador>
